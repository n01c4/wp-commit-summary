# GitHub
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Groq (https://console.groq.com/keys) — ücretsiz, sürdürülebilir, sınırsız aylık kullanım
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# Telegram
TELEGRAM_BOT_TOKEN=1234567890:AAHxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=-1001234567890

# Takip edilecek repolar (virgülle ayır)
REPOS=owner/repo1,owner/repo2,owner/repo3

# Cron saati (varsayılan: her gün 06:30)
CRON_SCHEDULE=30 6 * * *

# Özet dili
SUMMARY_LANGUAGE=tr
